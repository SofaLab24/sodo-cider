# Copy to .env.local (never commit secrets)

# Payload
PAYLOAD_SECRET=...
DATABASE_URL=postgresql://sodo:sodo@db_url/sodo_sidrine

# Public site URL (media + Stripe redirects)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# false = hide shop/cart/Stripe admin, redirect /shop and /cart (release mode)
# NEXT_PUBLIC_ENABLE_SHOP=false

# Stripe — test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# From: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOKS_ENDPOINT_SECRET=whsec_...
